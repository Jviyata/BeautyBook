generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  TECH
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      UserRole @default(USER)
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reviews   Review[]
  favorites Favorite[]
}

model Professional {
  id          String   @id @default(cuid())
  name        String
  bio         String?
  image       String?
  city        String
  state       String
  lat         Float?
  lng         Float?
  services    String[]
  priceMin    Int
  priceMax    Int
  phone       String?
  instagram   String?
  website     String?
  gallery     String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reviews     Review[]
  favorites   Favorite[]
  hours       Hours[]

  avgRating   Float?
  reviewCount Int    @default(0)
}

model Review {
  id             String       @id @default(cuid())
  rating         Int
  comment        String?
  createdAt      DateTime     @default(now())

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String

  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  professionalId String

  @@unique([userId, professionalId])
}

model Favorite {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String

  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  professionalId String

  @@unique([userId, professionalId])
}

model Hours {
  id             String       @id @default(cuid())
  day            String
  open           String
  close          String

  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  professionalId String
}
