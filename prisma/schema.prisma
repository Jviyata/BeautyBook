generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  TECH
}

enum MessageSenderType {
  USER
  TECH
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      UserRole @default(USER)
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reviews   Review[]
  favorites Favorite[]
  bookings  Booking[]
  conversations Conversation[]

  @@index([email])
}

model Professional {
  id          String   @id @default(cuid())
  name        String
  bio         String?
  image       String?
  email       String?
  city        String
  state       String
  lat         Float?
  lng         Float?
  services    String[]
  priceMin    Int
  priceMax    Int
  phone       String?
  instagram   String?
  website     String?
  gallery     String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reviews     Review[]
  favorites   Favorite[]
  hours       Hours[]
  bookings    Booking[]
  conversations Conversation[]

  avgRating   Float?
  reviewCount Int    @default(0)

  @@index([city])
  @@index([avgRating])
  @@index([name])
}

model Review {
  id             String       @id @default(cuid())
  rating         Int
  comment        String?
  createdAt      DateTime     @default(now())

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String

  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  professionalId String

  @@unique([userId, professionalId])
  @@index([userId])
  @@index([professionalId])
}

model Favorite {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  pinned         Boolean      @default(false)

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String

  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  professionalId String

  @@unique([userId, professionalId])
  @@index([userId])
  @@index([professionalId])
}

model Conversation {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  lastMessageAt  DateTime     @default(now())

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String

  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  professionalId String

  messages       Message[]

  @@unique([userId, professionalId])
  @@index([userId])
  @@index([professionalId])
  @@index([lastMessageAt])
}

model Message {
  id             String            @id @default(cuid())
  body           String
  senderType     MessageSenderType
  createdAt      DateTime          @default(now())

  conversation   Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String

  @@index([conversationId])
  @@index([createdAt])
}

model Booking {
  id             String       @id @default(cuid())
  date           DateTime
  notes          String?
  status         String       @default("pending")
  createdAt      DateTime     @default(now())

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String

  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  professionalId String

  @@index([userId])
  @@index([professionalId])
  @@index([date])
  @@index([status])
}

model Hours {
  id             String       @id @default(cuid())
  day            String
  open           String
  close          String

  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  professionalId String

  @@index([professionalId])
}
